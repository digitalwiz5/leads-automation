# Server
PORT=3000
NODE_ENV=development

# Webhook Security
WEBHOOK_SECRET=your-secret-token-here

# Database (PostgreSQL - Railway provides DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/leads_db

# Email (Nodemailer - Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Lead System <your@gmail.com>"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# CRM (HubSpot example)
HUBSPOT_API_KEY=your-hubspot-api-key

# Admin notifications
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PHONE=+972501234567

# Facebook Lead Ads
# FACEBOOK_VERIFY_TOKEN — המצאת בעצמך, כל string אקראי
FACEBOOK_VERIFY_TOKEN=my-random-verify-token-123
# FB_PAGE_TOKEN — מ-Meta Developers → Graph API Explorer → Generate Access Token
FB_PAGE_TOKEN=EAAxxxxxxxxxxxxxxxxx
