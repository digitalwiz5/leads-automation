    "pg": "^8.11.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "ts-node-dev": "^2.0.0"
  }
}
