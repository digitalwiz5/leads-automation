{
  "name": "leads-automation",
  "version": "1.0.0",
  "description": "Automated lead management system",
  "main": "dist/index.js",
  "scripts": {
    "build": "echo 'no build needed'",
    "start": "node -r ts-node/register src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
